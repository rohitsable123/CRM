# Express API server port
PORT=5000

# PostgreSQL database connection URI
# Local format: postgresql://[user]:[password]@[host]:[port]/[database_name]
# Supabase Transaction Mode connection (Pooler): postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase Direct Mode connection: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_db
